# OpenRouter API Configuration
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model Configuration
ANALYTICS_MODEL=openai/gpt-4o-mini
ANALYTICS_TEMPERATURE=0.3
ANALYTICS_MAX_TOKENS=2000

# MongoDB Configuration — same Atlas URI as backend
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DB_NAME=test

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=300

# RAG Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
RAG_TEMPERATURE=0.3
SYNC_INTERVAL_HOURS=1

# ElevenLabs TTS Configuration
# Get free key (10k chars/month) at: https://elevenlabs.io
ELEVENLABS_API_KEY=sk_your-key-here
# Female voice - Rachel (natural, warm, professional)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
